@page
@model GestionReservations.Pages.GestionVoitures.ModifierVoitureModel
@{
}
<h1>Modifier une voiture</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="Voiture.Id" />

            <div class="form-group mb-3">
                <label asp-for="Voiture.Marque" class="control-label">Marque de la voiture</label>
                <input asp-for="Voiture.Marque" class="form-control" />
                <span asp-validation-for="Voiture.Marque" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Voiture.Description" class="control-label">Description de la voiture</label>
                <input asp-for="Voiture.Description" class="form-control" />
                <span asp-validation-for="Voiture.Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Voiture.PrixJournalier" class="control-label">Prix de la voiture</label>
                <input asp-for="Voiture.PrixJournalier" class="form-control" />
                <span asp-validation-for="Voiture.PrixJournalier" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Voiture.AnneeFabrication" class="control-label">Année de fabrication de la voiture</label>
                <input asp-for="Voiture.AnneeFabrication" class="form-control" />
                <span asp-validation-for="Voiture.AnneeFabrication" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Enregistrer" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}